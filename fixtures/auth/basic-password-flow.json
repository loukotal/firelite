{
  "source": "manual-initial-contract",
  "service": "auth",
  "projectId": "demo-firelite",
  "description": "Initial Auth password flow fixture to be replaced or confirmed by official emulator discovery capture.",
  "steps": [
    {
      "name": "create-password-user",
      "request": {
        "method": "POST",
        "path": "/identitytoolkit.googleapis.com/v1/accounts:signUp?key=fake",
        "headers": {
          "content-type": "application/json"
        },
        "body": {
          "email": "alice@example.test",
          "password": "secret123",
          "returnSecureToken": true
        }
      },
      "response": {
        "status": 200,
        "bodyShape": {
          "kind": "identitytoolkit#SignupNewUserResponse",
          "localId": "<string>",
          "email": "alice@example.test",
          "idToken": "<jwt-like-string>",
          "refreshToken": "<string>",
          "expiresIn": "3600"
        }
      }
    },
    {
      "name": "sign-in-password-user",
      "request": {
        "method": "POST",
        "path": "/identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=fake",
        "body": {
          "email": "alice@example.test",
          "password": "secret123",
          "returnSecureToken": true
        }
      },
      "response": {
        "status": 200,
        "bodyShape": {
          "localId": "<same-as-create>",
          "email": "alice@example.test",
          "idToken": "<jwt-like-string>",
          "refreshToken": "<string>",
          "expiresIn": "3600"
        }
      }
    },
    {
      "name": "list-users",
      "request": {
        "method": "GET",
        "path": "/emulator/v1/projects/demo-firelite/accounts"
      },
      "response": {
        "status": 200,
        "bodyShape": {
          "users": [
            {
              "localId": "<same-as-create>",
              "email": "alice@example.test",
              "providerUserInfo": [
                {
                  "providerId": "password"
                }
              ]
            }
          ]
        }
      }
    },
    {
      "name": "delete-user",
      "request": {
        "method": "POST",
        "path": "/identitytoolkit.googleapis.com/v1/accounts:delete?key=fake",
        "body": {
          "localId": "<same-as-create>"
        }
      },
      "response": {
        "status": 200,
        "body": {}
      }
    }
  ]
}
